# ---- Anthropic (script + meta JSON) ----
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Default model; can be overridden per-video from the form.
MODEL=claude-sonnet-5

# ---- kie.ai (image generation: nano-banana / Gemini) ----
KEYAI_API_KEY=your-kie-ai-key-here
# Async jobs API. Leave these defaults unless kie.ai changes them.
KEYAI_ENDPOINT=https://api.kie.ai/api/v1/jobs/createTask
# Model: google/nano-banana (Gemini 2.5 Flash Image). Or google/nano-banana-pro.
KEYAI_MODEL=google/nano-banana
# 16:9 for YouTube. Options: 1:1 9:16 16:9 3:4 4:3 3:2 2:3 5:4 4:5 21:9 auto
KEYAI_ASPECT=16:9
KEYAI_OUTPUT_FORMAT=png

# ---- Neville channel names (edit these to your own) ----
PRODUCT_NAME=The 21 Nights Method
FUNNEL_CHANNEL=Divine Manifestation
